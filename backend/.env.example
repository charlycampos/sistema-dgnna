# ── Copiar este archivo como .env y ajustar los valores ──────────

# Clave secreta JWT (cambiar en producción)
SESSION_SECRET=dgnna-sistema-apelaciones-secret-2026

# ── Base de datos ─────────────────────────────────────────────────

# DESARROLLO: SQLite local (por defecto, no necesita configuración)
DATABASE_URL=sqlite:///./apelaciones.db

# PRODUCCIÓN con Oracle: descomentar y completar cuando esté listo
# DATABASE_URL=oracle+oracledb://usuario:password@host:1521/?service_name=ORCL
# También instalar: pip install oracledb
